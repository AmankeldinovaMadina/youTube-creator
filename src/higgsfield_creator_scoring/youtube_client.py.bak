from __future__ import annotations

import json
import logging
import time
from datetime import datetime, timezone
from typing import Any

from dateutil.parser import isoparse
from googleapiclient.discovery import Resource, build
from googleapiclient.errors import HttpError

from .models import AppConfig, VideoRecord

logger = logging.getLogger(__name__)


class YouTubeClient:
    def __init__(self, api_key: str, config: AppConfig) -> None:
        self.config = config
        self.api: Resource = build("youtube", "v3", developerKey=api_key)

    def _with_retry(self, fn, *args, **kwargs):
        for attempt in range(1, self.config.max_retries + 1):
            try:
                return fn(*args, **kwargs)
            except HttpError as exc:
                if self._is_non_retryable_quota_error(exc):
                    logger.warning("YouTube quota exhausted (non-retryable): %s", exc)
                    raise
                if attempt == self.config.max_retries:
                    raise
                sleep_for = self.config.retry_backoff_seconds * attempt
                logger.warning(
                    "YouTube transient error: %s; retrying in %ss", exc, sleep_for
                )
                time.sleep(sleep_for)

    @staticmethod
    def _is_non_retryable_quota_error(exc: HttpError) -> bool:
        if getattr(exc, "resp", None) is None or exc.resp.status != 403:
            return False

        try:
            payload = json.loads(exc.content.decode("utf-8")) if exc.content else {}
        except Exception:
            payload = {}

        reasons: list[str] = []
        for err in payload.get("error", {}).get("errors", []):
            reason = err.get("reason")
            if reason:
                reasons.append(str(reason))

        if not reasons:
            msg = str(exc)
            return "quotaExceeded" in msg or "dailyLimitExceeded" in msg

        return any(r in {"quotaExceeded", "dailyLimitExceeded"} for r in reasons)

    def search_videos(self, query: str, max_results: int) -> list[dict[str, Any]]:
        def _call():
            request = self.api.search().list(
                part="snippet",
                q=query,
                type="video",
                maxResults=max_results,
                order="relevance",
            )
            return request.execute()

        response = self._with_retry(_call)
        return response.get("items", [])

    def search_channels(self, query: str, max_results: int) -> list[dict[str, Any]]:
        def _call():
            request = self.api.search().list(
                part="snippet",
                q=query,
                type="channel",
                maxResults=max_results,
                order="relevance",
            )
            return request.execute()

        response = self._with_retry(_call)
        return response.get("items", [])

    def get_channels(self, channel_ids: list[str]) -> dict[str, dict[str, Any]]:
        if not channel_ids:
            return {}
        out: dict[str, dict[str, Any]] = {}
        for i in range(0, len(channel_ids), 50):
            batch = channel_ids[i : i + 50]

            def _call():
                request = self.api.channels().list(
                    part="snippet,statistics,contentDetails,brandingSettings",
                    id=",".join(batch),
                    maxResults=50,
                )
                return request.execute()

            response = self._with_retry(_call)
            for item in response.get("items", []):
                out[item["id"]] = item
        return out

    def get_recent_videos(
        self, channel: dict[str, Any], limit: int
    ) -> list[VideoRecord]:
        uploads_playlist = (
            channel.get("contentDetails", {}).get("relatedPlaylists", {}).get("uploads")
        )
        if not uploads_playlist:
            return []

        video_ids: list[str] = []
        next_page_token: str | None = None
        while len(video_ids) < limit:

            def _call_playlist():
                request = self.api.playlistItems().list(
                    part="contentDetails",
                    playlistId=uploads_playlist,
                    maxResults=min(50, limit),
                    pageToken=next_page_token,
                )
                return request.execute()

            response = self._with_retry(_call_playlist)
            items = response.get("items", [])
            for item in items:
                video_id = item.get("contentDetails", {}).get("videoId")
                if video_id:
                    video_ids.append(video_id)
                if len(video_ids) >= limit:
                    break
            next_page_token = response.get("nextPageToken")
            if not next_page_token:
                break

        videos: list[VideoRecord] = []
        for i in range(0, len(video_ids), 50):
            batch = video_ids[i : i + 50]

            def _call_videos():
                request = self.api.videos().list(
                    part="snippet,statistics",
                    id=",".join(batch),
                    maxResults=50,
                )
                return request.execute()

            response = self._with_retry(_call_videos)
            for item in response.get("items", []):
                snippet = item.get("snippet", {})
                stats = item.get("statistics", {})
                published_raw = snippet.get("publishedAt")
                if not published_raw:
                    continue
                videos.append(
                    VideoRecord(
                        video_id=item["id"],
                        title=snippet.get("title", ""),
                        description=snippet.get("description", ""),
                        url=f"https://www.youtube.com/watch?v={item['id']}",
                        views=int(stats.get("viewCount", 0)),
                        comment_count=int(stats.get("commentCount", 0)),
                        published_at=isoparse(published_raw).astimezone(timezone.utc),
                    )
                )
        videos.sort(key=lambda v: v.published_at, reverse=True)
        return videos[:limit]

    def get_recent_comments(self, video_id: str, max_comments: int) -> list[str]:
        comments: list[str] = []
        next_page_token: str | None = None
        while len(comments) < max_comments:

            def _call_comments():
                request = self.api.commentThreads().list(
                    part="snippet",
                    videoId=video_id,
                    maxResults=min(100, max_comments - len(comments)),
                    textFormat="plainText",
                    order="relevance",
                    pageToken=next_page_token,
                )
                return request.execute()

            try:
                response = self._with_retry(_call_comments)
            except HttpError:
                return comments

            for item in response.get("items", []):
                snippet = (
                    item.get("snippet", {})
                    .get("topLevelComment", {})
                    .get("snippet", {})
                )
                text = snippet.get("textDisplay")
                if text:
                    comments.append(text)
            next_page_token = response.get("nextPageToken")
            if not next_page_token:
                break
        return comments


def iso_now() -> str:
    return datetime.now(timezone.utc).isoformat()
